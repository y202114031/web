<div class="my-5">
    <h1 class="text-center">학생관리</h1>
    <div class="text-end mb-2">
        <a class="btn btn-primary px-5" href="/haksa/stu/insert">학생등록</a>
    </div>
    <table id="tbl" class="table table-striped table-hover"></table>
    <script id="temp" type="text/x-handlebars-template">
        <tbody>
            {{#each .}}
            <tr>
                <td>{{SCODE}}</td>
                <td>{{SNAME}}</td>
                <td>{{DEPT}}</td>
                <td>{{FDATE}}</td>
                <td>{{YEAR}}</td>
                <td>{{PNAME}}({{ADVISOR}})</td>
                <td class="text-end">
                    <button class="btn btn-outline-danger btn-sm" scode="{{SCODE}}">삭제</button>

                </td>
            </tr>
            {{/each}}
        </tbody>
    </script>
</div>
<script>
    getList();
    //삭제버튼을 클릭한 경우
    $("#tbl").on("click",".btn-sm",function(){
        const scode=$(this).attr("scode");
        if(confirm(`${scode}번 학생을 삭제하실래요?`)){
            $.ajax({
                type:"post",
                url:"/haksa/stu/delete",
                data:{scode},
                success:function(){
                    getList();
                },
                error:function(){
                    alert("학생 삭제를 실패했습니다.");
                }
            })
        }

    });
    function getList(){
        $.ajax({
            type:"get",
            url:"/haksa/stu/list.json",
            success:function(data){
                console.log(data);
                const temp=Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(data));
            }
        })
    }
</script>